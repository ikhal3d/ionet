# ionet backend — production Caddy.
#
# Listens on the host name {$DOMAIN} (default origin.ionet.com.au), which
# the Cloudflare Worker forwards /api/* requests to over HTTPS:8443.
#
# TLS: Let's Encrypt via Cloudflare DNS-01 (port 80 is busy on this VM —
# genesis_nginx owns it). Requires the cloudflare DNS provider plugin
# baked into the Caddy image — see ./Dockerfile.

{
	email {$ACME_EMAIL}
	acme_dns cloudflare {$CF_API_TOKEN}
}

{$DOMAIN} {
	encode gzip zstd

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options    "nosniff"
		X-Frame-Options           "DENY"
		Referrer-Policy           "strict-origin-when-cross-origin"
		Permissions-Policy        "geolocation=(), camera=(), microphone=()"
		Server                    "ionet"
		-X-Powered-By
	}

	# CORS — only the live frontend origin gets answered, even though
	# Cloudflare Worker should be the only thing reaching us anyway.
	@cors_preflight method OPTIONS
	header @cors_preflight {
		Access-Control-Allow-Origin       "{$FRONTEND_ORIGIN}"
		Access-Control-Allow-Methods      "GET, POST, OPTIONS"
		Access-Control-Allow-Headers      "Content-Type, X-Turnstile-Token"
		Access-Control-Max-Age            "86400"
	}
	respond @cors_preflight 204

	header {
		Access-Control-Allow-Origin "{$FRONTEND_ORIGIN}"
		Vary                        "Origin"
	}

	# Explicit routing — handle blocks eliminate directive-ordering
	# ambiguity between reverse_proxy and the catch-all 404.
	handle /healthz {
		respond 200 {
			body "ok"
		}
	}

	handle /api/* {
		reverse_proxy tools-api:8000
	}

	handle {
		respond 404
	}
}

