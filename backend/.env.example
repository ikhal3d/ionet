# ionet backend — environment template.
# Copy to .env on the VM. Never commit a real .env (it's git-ignored).

# ── Caddy config selector ─────────────────────────────────────────────
# Caddyfile        production: TLS via Let's Encrypt DNS-01 (needs CF_API_TOKEN)
# Caddyfile.local  local test: self-signed cert via `tls internal`
CADDY_CONFIG=Caddyfile.local

# ── Public hostnames (must resolve to the VM's public IP via DNS) ─────
DOMAIN=tools.ionet.com.au
LG_DOMAIN=lg.ionet.com.au

# ── Frontend origin allowed by CORS ───────────────────────────────────
FRONTEND_ORIGIN=https://ionet.com.au

# ── Let's Encrypt ─────────────────────────────────────────────────────
# Caddy uses DNS-01 via Cloudflare. HTTP-01 won't work because port 80
# is already in use by the genesis container.
ACME_EMAIL=admin@ionet.com.au
CF_API_TOKEN=                    # Cloudflare API token, scope: Zone DNS edit (used by Caddy)
CF_RADAR_TOKEN=                  # Cloudflare API token with Account Analytics: Read
                                 # (used by outage-aggregator for Cloudflare Radar). If
                                 # empty, falls back to CF_API_TOKEN — that token's scope
                                 # may NOT include Radar.

# ── Cloudflare Turnstile (invisible captcha) ──────────────────────────
# Get a site/secret pair from https://dash.cloudflare.com → Turnstile.
# Frontend embeds the *site key* (public). Backend verifies with the
# *secret key* (must never reach the browser).
TURNSTILE_SITE_KEY=               # public — added to tools.html later
TURNSTILE_SECRET=                 # private — server-side verification
REQUIRE_TURNSTILE=false           # flip to true once site key is wired

# ── Logging ──────────────────────────────────────────────────────────
LOG_LEVEL=info

# ── Outage aggregator ────────────────────────────────────────────────
REFRESH_INTERVAL=300              # seconds between feed pulls

# ── Optional API keys for richer Phase 3 data (each endpoint works
#     without these — they only unlock additional sources / higher rate)
ABUSEIPDB_API_KEY=                # https://www.abuseipdb.com/account/api  (free 1,000/day)
NVD_API_KEY=                      # https://nvd.nist.gov/developers/request-an-api-key  (5 req/30s without)
